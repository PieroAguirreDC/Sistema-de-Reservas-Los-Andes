      "module": "module.s3",
      "mode": "data",
      "type": "aws_iam_policy_document",
      "name": "backend_uploads_access",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "1142892156",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"AllowPutPublicImages\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"s3:PutObject\",\n      \"Resource\": \"arn:aws:s3:::reservas-dev-uploads-public/*\",\n      \"Condition\": {\n        \"StringLike\": {\n          \"s3:content-type\": [\n            \"image/jpeg\",\n            \"image/png\",\n            \"image/webp\"\n          ]\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowPutPrivateFiles\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"s3:PutObject\",\n      \"Resource\": \"arn:aws:s3:::reservas-dev-uploads-private/*\",\n      \"Condition\": {\n        \"StringLike\": {\n          \"s3:content-type\": [\n            \"image/jpeg\",\n            \"image/png\",\n            \"image/webp\",\n            \"application/pdf\"\n          ]\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowGetPrivateFiles\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"s3:GetObject\",\n      \"Resource\": \"arn:aws:s3:::reservas-dev-uploads-private/*\"\n    },\n    {\n      \"Sid\": \"AllowGetPublicImages\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"s3:GetObject\",\n      \"Resource\": \"arn:aws:s3:::reservas-dev-uploads-public/*\"\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"AllowPutPublicImages\",\"Effect\":\"Allow\",\"Action\":\"s3:PutObject\",\"Resource\":\"arn:aws:s3:::reservas-dev-uploads-public/*\",\"Condition\":{\"StringLike\":{\"s3:content-type\":[\"image/jpeg\",\"image/png\",\"image/webp\"]}}},{\"Sid\":\"AllowPutPrivateFiles\",\"Effect\":\"Allow\",\"Action\":\"s3:PutObject\",\"Resource\":\"arn:aws:s3:::reservas-dev-uploads-private/*\",\"Condition\":{\"StringLike\":{\"s3:content-type\":[\"image/jpeg\",\"image/png\",\"image/webp\",\"application/pdf\"]}}},{\"Sid\":\"AllowGetPrivateFiles\",\"Effect\":\"Allow\",\"Action\":\"s3:GetObject\",\"Resource\":\"arn:aws:s3:::reservas-dev-uploads-private/*\"},{\"Sid\":\"AllowGetPublicImages\",\"Effect\":\"Allow\",\"Action\":\"s3:GetObject\",\"Resource\":\"arn:aws:s3:::reservas-dev-uploads-public/*\"}]}",
