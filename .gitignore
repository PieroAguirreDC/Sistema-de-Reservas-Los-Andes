**/node_modules/
**/.next/
**/dist/

# ─── Secrets y Variables de Entorno ──────────────────────────────────────────
# Ignorar todos los archivos de entorno
**/.env*
# Permitir explícitamente archivos de ejemplo/plantillas
!**/.env.example
!**/.env.template
# ─── Terraform ───────────────────────────────────────────────────────────────
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup
**/tfplan
**/*.tfplan
# NUNCA commitear archivos con secrets — solo terraform.tfvars (sin secrets) es seguro
# Archivos de override locales
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json
# Logs de crash
**/crash.log
**/crash.*.log

echo "results.xml" >> .gitignore
echo "results_after.xml" >> .gitignore
echo "*.xml" >> .gitignore
git add .gitignore
git commit -m "chore(gitignore): exclude Checkov XML output files from version control"
git push origin hotfix